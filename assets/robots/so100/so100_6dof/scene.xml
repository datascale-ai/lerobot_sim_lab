<mujoco model="so_arm100_scene">
  <compiler angle="radian" meshdir="so100_meshes/"/>

  <option cone="elliptic" impratio="10" timestep="0.002" gravity="0 0 -9.81" density="1.2" viscosity="0.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    
    <material name="floor_mat" rgba="0.1 0.15 0.25 1" specular="0.1" shininess="0.2"/>
    
    <material name="black_plastic" rgba="0.15 0.15 0.15 1" specular="0.3" shininess="0.2"/>
    <material name="fabric_dark" rgba="0.1 0.1 0.1 1" specular="0.1" shininess="0"/>
    <material name="paper_white" rgba="0.95 0.95 0.95 1" specular="0" shininess="0"/>
    
    <material name="cardboard_white" rgba="0.9 0.9 0.9 1" specular="0.1" shininess="0"/>
    
    <texture name="box_front_tex" type="2d" file="so100_meshes/box_front.png" width="1" height="1"/>
    <texture name="box_side_tex" type="2d" file="so100_meshes/box_side.png" width="1" height="1"/>
    <texture name="box_inside_tex" type="2d" file="so100_meshes/box_inside.png"/>
    
    <material name="box_front_mat" texture="box_front_tex" texrepeat="1 1" texuniform="false" rgba="1 1 1 1"/>
    <material name="box_side_mat" texture="box_side_tex" texrepeat="1 1" texuniform="false" rgba="1 1 1 1"/>
    <material name="box_inside_mat" texture="box_inside_tex" rgba="1 1 1 1"/>

    <texture name="pen1_tex" type="2d" file="so100_meshes/pen1.png"/>
    <texture name="pen2_tex" type="2d" file="so100_meshes/pen2.png"/>
    <texture name="pen3_tex" type="2d" file="so100_meshes/pen3.png"/>
    <texture name="pen4_tex" type="2d" file="so100_meshes/pen4.png"/>
    
    <material name="pen1_mat" texture="pen1_tex" texuniform="true" specular="0.5" shininess="0.5" rgba="1 1 1 1"/>
    <material name="pen2_mat" texture="pen2_tex" texuniform="true" specular="0.5" shininess="0.5" rgba="1 1 1 1"/>
    <material name="pen3_mat" texture="pen3_tex" texuniform="true" specular="0.5" shininess="0.5" rgba="1 1 1 1"/>
