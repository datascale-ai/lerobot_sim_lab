    <mesh name="pen_mesh" file="Jcjensonpen.obj" scale="0.009 0.009 0.009"/>
    <mesh name="pen1_mesh" file="Sketchfabpen.obj" scale="0.03 0.03 0.03"/>

    <texture name="table_wood_tex" type="2d" file="so100_meshes/wood_texture.png" width="512" height="512"/>
    <material name="wood_table" texture="table_wood_tex" texrepeat="2 2" texuniform="true" specular="0.1" shininess="0.1"/>

    <material name="blue" rgba="0.2 0.6 0.8 1.0" specular="0.1" shininess="0.1"/>
    <material name="black" rgba="0.1 0.1 0.1 1.0" specular="0.1" shininess="0.1"/>

    <mesh name="Base" file="Base.stl"/>
    <mesh name="Base_Motor" file="Base_Motor.stl"/>
    <mesh name="Rotation_Pitch" file="Rotation_Pitch.stl"/>
    <mesh name="Rotation_Pitch_Motor" file="Rotation_Pitch_Motor.stl"/>
